FROM ghcr.io/axeltec-software/vllm:v0.11-gonka-candidate

# copy ONLY the patched OpenAI files
COPY ./vllm/entrypoints/openai/cli_args.py /tmp/vllm_patch/entrypoints/openai/cli_args.py
COPY ./vllm/entrypoints/openai/protocol.py /tmp/vllm_patch/entrypoints/openai/protocol.py
COPY ./vllm/entrypoints/openai/serving_engine.py /tmp/vllm_patch/entrypoints/openai/serving_engine.py
COPY ./vllm/entrypoints/openai/serving_chat.py /tmp/vllm_patch/entrypoints/openai/serving_chat.py
COPY ./vllm/entrypoints/openai/serving_completion.py /tmp/vllm_patch/entrypoints/openai/serving_completion.py

RUN set -euo pipefail; \
  VLLM_PKG_DIR="$(python3 -c 'import pathlib, vllm; print(pathlib.Path(vllm.__file__).resolve().parent)')"; \
  install -D -m 0644 /tmp/vllm_patch/entrypoints/openai/cli_args.py         "${VLLM_PKG_DIR}/entrypoints/openai/cli_args.py"; \
  install -D -m 0644 /tmp/vllm_patch/entrypoints/openai/protocol.py         "${VLLM_PKG_DIR}/entrypoints/openai/protocol.py"; \
  install -D -m 0644 /tmp/vllm_patch/entrypoints/openai/serving_engine.py   "${VLLM_PKG_DIR}/entrypoints/openai/serving_engine.py"; \
  install -D -m 0644 /tmp/vllm_patch/entrypoints/openai/serving_chat.py     "${VLLM_PKG_DIR}/entrypoints/openai/serving_chat.py"; \
  install -D -m 0644 /tmp/vllm_patch/entrypoints/openai/serving_completion.py "${VLLM_PKG_DIR}/entrypoints/openai/serving_completion.py"; \
  rm -rf /tmp/vllm_patch